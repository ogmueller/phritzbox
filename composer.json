{
  "license": "proprietary",
  "type": "project",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": "^8.5",
    "ext-pdo_sqlite": "*",
    "ext-simplexml": "*",
    "doctrine/doctrine-bundle": "^3.0",
    "doctrine/doctrine-migrations-bundle": "^4.0",
    "doctrine/orm": "^3.0",
    "noximo/php-colored-ascii-linechart": "dev-master",
    "symfony/cache": "^8.0",
    "symfony/console": "^8.0",
    "symfony/dotenv": "^8.0",
    "symfony/flex": "^2.0",
    "symfony/framework-bundle": "^8.0",
    "symfony/http-client": "^8.0",
    "symfony/monolog-bundle": "^4.0",
    "symfony/runtime": "^8.0",
    "symfony/string": "^8.0",
    "symfony/yaml": "^8.0"
  },
  "require-dev": {
    "dama/doctrine-test-bundle": "^8.0",
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpmd/phpmd": "@stable",
    "phpunit/phpunit": "^11.0",
    "roave/security-advisories": "dev-latest",
    "squizlabs/php_codesniffer": "*",
    "symfony/debug-bundle": "^8.0",
    "symfony/maker-bundle": "^1.11",
    "symfony/phpunit-bridge": "^8.0",
    "symfony/stopwatch": "^8.0",
    "symfony/var-dumper": "^8.0"
  },
  "config": {
    "platform": {
      "php": "8.5.4"
    },
    "preferred-install": {
      "*": "dist"
    },
    "sort-packages": true,
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    }
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "require": "8.0.*",
      "allow-contrib": true
    }
  }
}
