{
	frankenphp
	order php_server before file_server
}

{$SERVER_NAME:http://localhost} {
	root * /application/app/public

	header {
		X-Frame-Options SAMEORIGIN
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://assets.avm.de;"
		# Only honoured by browsers over HTTPS; harmless on plain-HTTP LAN setups.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Lock down powerful browser features this dashboard never uses.
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	@assets path /frontend/assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	php_server
}
