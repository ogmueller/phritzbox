# Fritz!Box credentials (required)
APP_API_USERNAME=your-fritzbox-username
APP_API_PASSWORD=your-fritzbox-password
APP_API_DOMAIN=http://fritz.box

# Security (change these for production!)
APP_SECRET=change-me-to-a-random-string
JWT_PASSPHRASE=change-me-to-a-random-passphrase

# Server name / domain (default: localhost)
# SERVER_NAME=localhost

# Port to expose the web UI (default: 80)
# PHRITZBOX_PORT=80
