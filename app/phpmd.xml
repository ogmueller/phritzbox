<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="Phritzbox"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd"
         xsi:noNamespaceSchemaLocation="http://pmd.sf.net/ruleset_xml_schema.xsd">

    <description>Phritzbox PHPMD ruleset</description>

    <!-- Exclude generated/framework-managed directories -->
    <exclude-pattern>*/Entity/*</exclude-pattern>
    <exclude-pattern>*/Kernel.php</exclude-pattern>

    <rule ref="rulesets/codesize.xml"/>
    <rule ref="rulesets/design.xml"/>
    <rule ref="rulesets/unusedcode.xml"/>

    <rule ref="rulesets/naming.xml">
        <!-- Allow short variable names common in loops and math -->
        <exclude name="ShortVariable"/>
    </rule>

</ruleset>
